{
  "name": "boat-rental-booking",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @boat/db prisma:generate",
    "db:migrate": "pnpm --filter @boat/db prisma:migrate",
    "db:push": "pnpm --filter @boat/db prisma:push",
    "db:seed": "pnpm --filter @boat/db prisma:seed",
    "dev:site": "turbo dev --filter=@boat/site",
    "dev:booking": "turbo dev --filter=@boat/booking",
    "dev:admin": "turbo dev --filter=@boat/admin"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "eslint": "9.39.4",
    "pnpm": "10.32.1",
    "turbo": "2.8.20",
    "typescript": "5.9.3"
  }
}
